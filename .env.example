# ── websim AI agent secrets ──
# NEVER commit this file. Copy it to .env and fill in your values.

# ── API Provider (OpenAI-compatible) ──
# Your proxy / endpoint. Must speak OpenAI chat-completions format.
# The agent sends tools + messages and expects tool_calls back.
OPENAI_BASE_URL=https://funny.doxi.dpdns.org/v1
OPENAI_API_KEY=8ff4b4a9a348b68937b80871331f5ffcdaa5435f85cf2b3211856e111eb33a54
OPENAI_MODEL=claude-opus-4-5-20251001

# Does your endpoint support image input (vision)?
# true  = agent can analyze screenshots of websim projects
# false = text-only mode
OPENAI_VISION_SUPPORT=false

# ── websim auth ──
# Your websim Supabase JWT (grab from browser devtools while logged in).
# Network tab → any api/v1 request → Authorization: Bearer <this>
WEBSIM_BEARER=YOUR_WEBSIM_JWT_HERE

# ── Agent settings ──
# Max tool-calling loop iterations (prevents infinite loops)
AGENT_MAX_TURNS=15
# Daemon polling interval in minutes (API check is cheap, AI only fires for new comments)
AGENT_WATCH_INTERVAL_MINUTES=30
# Auto-prune state entries older than this many days
AGENT_STATE_MAX_AGE_DAYS=90
# Extra verbose logging
AGENT_DEBUG=false
